# Auto-provisioned by EdgeOne CLI during deployment.
AI_GATEWAY_API_KEY=
AI_GATEWAY_BASE_URL=
AI_GATEWAY_MODEL=@makers/deepseek-v4-flash

# This repository is a personal single-owner demo. Business state is stored in
# Makers Conversation Store, LangGraph Store and Pages Blob; no SQL database is required.

# Optional one-time SQLite bundle import. Remove after migration.
LEGACY_IMPORT_SECRET=

# Optional quota-only fallback. Makers AI Gateway remains the primary model.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Set manually when the Makers web_search tool is enabled.
WSA_API_KEY=

# Tencent Location Service server key (place search + road directions).
TENCENT_MAP_SERVER_KEY=
# TokenHub key shared by multimodal review and optional image generation.
HUNYUAN_IMAGE_API_KEY=
HUNYUAN_IMAGE_BASE_URL=https://tokenhub.tencentmaas.com
HUNYUAN_IMAGE_MODEL=hy-image-v3.0
# Optional dedicated overrides for rich-search visual review.
HUNYUAN_VISION_API_KEY=
HUNYUAN_VISION_BASE_URL=https://tokenhub.tencentmaas.com
HUNYUAN_VISION_MODEL=hy-vision-2.0-instruct

# Optional visual fallback with a recurring free allocation (Workers AI free
# allocation resets daily). The same token supports vision, text-to-image and
# image-to-image. Hunyuan remains first when both are configured.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_WORKERS_AI_TOKEN=
CLOUDFLARE_VISION_MODEL=@cf/meta/llama-3.2-11b-vision-instruct
CLOUDFLARE_IMAGE_MODEL=@cf/black-forest-labs/flux-1-schnell
CLOUDFLARE_IMAGE_EDIT_MODEL=@cf/runwayml/stable-diffusion-v1-5-img2img

# Optional vision-only fallbacks. DashScope's new-user quota expires; Gemini
# has a free vision tier but its image generation API currently requires paid billing.
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode
DASHSCOPE_VISION_MODEL=qwen3-vl-flash
GEMINI_API_KEY=
GEMINI_OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
GEMINI_VISION_MODEL=gemini-2.5-flash-lite

# Rich-search hard budgets. Defaults total about 22 seconds before model answer synthesis.
RICH_SEARCH_PROVIDER_TIMEOUT_SECONDS=10
RICH_SEARCH_MEDIA_TIMEOUT_SECONDS=5
RICH_SEARCH_VISION_TIMEOUT_SECONDS=7
REFERENCE_VISION_TIMEOUT_SECONDS=8

# Optional personal Tencent Meeting Skill. Obtain the personal token from
# https://meeting.tencent.com/ai-skill and store it only as a Makers secret.
TENCENT_MEETING_TOKEN=
TENCENT_MEETING_MCP_URL=https://mcp.meeting.tencent.com/mcp/wemeet-open/v1
TENCENT_MEETING_SKILL_VERSION=v1.0.11

# Tencent Maps JS API key used by the production location workspace.
VITE_TENCENT_MAP_KEY=
