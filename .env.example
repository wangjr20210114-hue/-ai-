# Auto-provisioned by EdgeOne CLI during deployment.
AI_GATEWAY_API_KEY=
AI_GATEWAY_BASE_URL=
AI_GATEWAY_MODEL=@makers/deepseek-v4-flash

# Optional quota-only fallback. Makers AI Gateway remains the primary model.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Set manually when the Makers web_search tool is enabled.
WSA_API_KEY=

# Tencent Location Service server key (place search + road directions).
TENCENT_MAP_SERVER_KEY=

# Optional Hunyuan TokenHub image generation.
HUNYUAN_IMAGE_API_KEY=
HUNYUAN_IMAGE_BASE_URL=https://tokenhub.tencentmaas.com
HUNYUAN_IMAGE_MODEL=hy-image-lite

# Persistent tmeet bridge (required on EdgeOne; CLI credentials are device-bound)
MEETING_BRIDGE_URL=
MEETING_BRIDGE_TOKEN=

# Optional legacy/local OSM database. Never commit real credentials.
PLACE_DB_HOST=
PLACE_DB_PORT=5432
PLACE_DB_NAME=osm
PLACE_DB_USER=
PLACE_DB_PASSWORD=

# Tencent Maps JS API key used by the production location workspace.
VITE_TENCENT_MAP_KEY=
