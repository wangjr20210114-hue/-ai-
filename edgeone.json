{
  "buildCommand": "cd frontend && npm ci && npm run build -- --mode edgeone",
  "outputDirectory": "frontend/dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/test-cases",
      "destination": "/test-cases/index.html"
    },
    {
      "source": "/test-cases/",
      "destination": "/test-cases/index.html"
    }
  ],
  "cloudFunctions": {
    "nodejs": {
      "includeFiles": []
    }
  },
  "agents": {
    "framework": "langgraph",
    "timeout": 1800
  },
  "schedules": [
    {
      "name": "proactive-daily-scan",
      "cron": "0 8 * * *",
      "path": "/proactive-tick",
      "method": "POST",
      "payload": { "operation": "tick" },
      "timezone": "Asia/Shanghai"
    }
  ]
}
