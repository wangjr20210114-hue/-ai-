{
  "buildCommand": "cd frontend && npm ci && npm run build",
  "outputDirectory": "frontend/dist",
  "framework": "vite",
  "agents": {
    "framework": "langgraph",
    "timeout": 1800
  },
  "cloudFunctions": {
    "python": {
      "includeFiles": []
    }
  },
  "rewrites": [
    {
      "source": "/api/messages",
      "destination": "/cloud-functions/messages"
    },
    {
      "source": "/api/search/:path*",
      "destination": "http://94.16.110.28:8000/api/search/:path*"
    }
  ]
}
