{
  "buildCommand": "cd frontend && npm ci && npm run build -- --mode edgeone",
  "outputDirectory": "frontend/dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/test-cases",
      "destination": "/test-cases-entry.html"
    },
    {
      "source": "/test-cases/",
      "destination": "/test-cases-entry.html"
    }
  ],
  "cloudFunctions": {
    "nodejs": {
      "includeFiles": [],
      "maxDuration": 120
    }
  },
  "agents": {
    "framework": "langgraph",
    "timeout": 1800
  },
  "schedules": [
    {
      "name": "proactive-daily-scan",
      "cron": "0 8 * * *",
      "path": "/proactive",
      "method": "POST",
      "payload": { "operation": "tick", "trigger": "edgeone_schedule" },
      "timezone": "Asia/Shanghai"
    }
  ]
}
