# ===== LLM 提供方：hunyuan | deepseek =====
LLM_PROVIDER=deepseek

# ===== 混元大模型 API（OpenAI 兼容接口）=====
HUNYUAN_API_KEY=sk-your-hunyuan-api-key
HUNYUAN_BASE_URL=https://api.hunyuan.cloud.tencent.com/v1
HUNYUAN_MODEL=hunyuan-turbo
HUNYUAN_IMAGE_MODEL=hunyuan-image

# ===== DeepSeek API（OpenAI 兼容接口）=====
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ===== 腾讯会议 API =====
# https://cloud.tencent.com/document/product/1095
TENCENT_MEETING_APP_ID=your-app-id
TENCENT_MEETING_SDK_ID=your-sdk-id
TENCENT_MEETING_SECRET_ID=your-secret-id
TENCENT_MEETING_SECRET_KEY=your-secret-key
TENCENT_MEETING_OPERATOR_ID=your-operator-id
TENCENT_MEETING_BASE_URL=https://api.meeting.qq.com

# ===== 应用配置 =====
APP_HOST=0.0.0.0
APP_PORT=8000
DB_PATH=./yuanbao.db
# 为 true 时返回模拟数据（无真实密钥时便于离线演示）
MOCK_MODE=false
