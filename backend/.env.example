# ===== LLM 提供方：hunyuan | deepseek =====
LLM_PROVIDER=hunyuan

# ===== 混元大模型 API（OpenAI 兼容接口 / LKEAP）=====
HUNYUAN_API_KEY=sk-your-hunyuan-api-key
HUNYUAN_BASE_URL=https://api.lkeap.cloud.tencent.com/plan/v3
HUNYUAN_MODEL=hy3
HUNYUAN_VISION_MODEL=hunyuan-vision

# ===== 混元文生图 API（TokenHub）=====
HUNYUAN_IMAGE_API_KEY=
HUNYUAN_IMAGE_BASE_URL=https://tokenhub.tencentmaas.com
HUNYUAN_IMAGE_MODEL=hy-image-lite

# ===== DeepSeek API（意图识别/结构化任务/搜索总结）=====
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ===== WSA 联网搜索（可选兜底）=====
WSA_API_KEY=
WSA_BASE_URL=https://api.wsa.cloud.tencent.com

# ===== 腾讯位置服务 =====
TENCENT_MAP_KEY=

# ===== 腾讯会议 =====
# 当前代码通过 tmeet CLI 创建会议；首次使用需在终端执行：tmeet auth login

# ===== 应用配置 =====
APP_HOST=0.0.0.0
APP_PORT=8000
DB_PATH=./yuanbao.db
FILE_STORAGE_DIR=./uploads/files
MOCK_MODE=false

# Local-only security boundary
APP_HOST=127.0.0.1
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
LOCAL_AUTH_ENABLED=true
AGENT_STATE_DIR=./.agent
# Optional fixed token. Leave empty to generate ./.agent/access-token on first start.
LOCAL_ACCESS_TOKEN=
LOCAL_TOKEN_PATH=./.agent/access-token
